# LLM
OPENAI_API_KEY=sk-...

# PostgreSQL - data queries (should use a read-only user)
DATA_POSTGRES_URL=postgresql://readonly_user:password@localhost:5432/data_agent

# PostgreSQL - LangGraph checkpoint persistence (needs write access)
STATE_POSTGRES_URL=postgresql://agent_user:password@localhost:5432/data_agent

# Google Analytics 4
GA_PROPERTY_ID=123456789
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Report output
REPORT_OUTPUT_DIR=./reports
